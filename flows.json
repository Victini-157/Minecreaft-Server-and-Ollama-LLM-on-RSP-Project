    {
        "id": "0ffabf52d01966af",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "function 1",
        "func": "if (msg.payload.models && msg.payload.models.length > 0) {\n    let activeModels = msg.payload.models.map(m => m.model || m.name).join(\", \");\n    msg.payload = \"🟢 Ollama Bot is ONLINE||Active Model: \" + activeModels;\n} else {\n    msg.payload = \"🔴 Ollama Bot is OFFLINE - No models running\";\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 960,
        "wires": [
