            ]
        ]
    },
    {
        "id": "e439638b2396c78f",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "function 5",
        "func": "const playerCount = msg.payload?.online || 0;\nmsg.payload = playerCount.toString();\nreturn msg;",
