                "e7453886503065c3"
            ]
        ]
    },
    {
        "id": "cbdee7a796e04bf1",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "function 2",
        "func": "const isOnline = msg.payload?.online !== undefined && msg.payload.online > 0;\nmsg.payload = isOnline ? \"🟢 Server Online\" : \"🔴 Server Offline\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 620,
        "wires": [
